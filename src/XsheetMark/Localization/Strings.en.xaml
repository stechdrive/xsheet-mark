<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">
    <s:String x:Key="Tooltip.Pen">Pen</s:String>
    <s:String x:Key="Tooltip.Eraser">Eraser</s:String>
    <s:String x:Key="Tooltip.Move">Move images</s:String>
    <s:String x:Key="Tooltip.ColorBlack">Black</s:String>
    <s:String x:Key="Tooltip.ColorRed">Red</s:String>
    <s:String x:Key="Tooltip.ColorBlue">Blue</s:String>
    <s:String x:Key="Tooltip.ColorGreen">Green</s:String>
    <s:String x:Key="Tooltip.ColorYellow">Yellow</s:String>
    <s:String x:Key="Tooltip.WidthThin">Thin</s:String>
    <s:String x:Key="Tooltip.WidthMedium">Medium</s:String>
    <s:String x:Key="Tooltip.WidthThick">Thick</s:String>
    <s:String x:Key="Tooltip.FitAll">Fit all</s:String>
    <s:String x:Key="Tooltip.Close">Close</s:String>

