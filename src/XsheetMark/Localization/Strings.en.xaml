    <s:String x:Key="Status.Skipped">   [{0} skipped]</s:String>
    <s:String x:Key="Status.StrokeInfo">Strokes: {0}   pressure: {1:F2}–{2:F2} {3}   zoom: {4:F0}%</s:String>
    <s:String x:Key="Pressure.Flat">(flat)</s:String>
    <s:String x:Key="Pressure.Varies">(varies)</s:String>

    <s:String x:Key="ToolName.Pen">Pen</s:String>
    <s:String x:Key="ToolName.Eraser">Eraser</s:String>
    <s:String x:Key="ToolName.Move">Move</s:String>
</ResourceDictionary>
