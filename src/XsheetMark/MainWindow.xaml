<Window x:Class="XsheetMark.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XsheetMark"
        mc:Ignorable="d"
        Title="xsheet-mark"
        Icon="/icon.ico"
        Height="820" Width="1000"
        MinHeight="240" MinWidth="360"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        AllowDrop="True"
        DragOver="OnDragOver"
        Drop="OnDrop"
        PreviewMouseDown="OnWindowPreviewMouseDown">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo>
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfo x:Name="LockThumbButton"
                                 Description="{DynamicResource ClickThrough.ThumbLock}"
                                 ImageSource="/lock.ico"
                                 Click="ToggleClickThrough_ThumbClick"/>
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="RadioButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#5090CCFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CurrentColorSwatch" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E04040"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ring" Width="32" Height="32" Stroke="#80FFFFFF" StrokeThickness="2"/>
                            <Ellipse Width="24" Height="24" Fill="{TemplateBinding Background}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ring" Property="Stroke" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupColorSwatch" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ring" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2"/>
                            <Ellipse Width="20" Height="20" Fill="{TemplateBinding Background}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ring" Property="Stroke" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder" Background="#25000000" BorderBrush="#80FFFFFF" BorderThickness="1">
        <Grid>
            <Canvas x:Name="Viewport"
                    Margin="0,28,0,0"
                    ClipToBounds="True"
                    Background="Transparent"
                    PreviewMouseWheel="Viewport_PreviewMouseWheel"
                    PreviewMouseDown="Viewport_PreviewMouseDown"
                    MouseMove="Viewport_MouseMove"
                    PreviewMouseUp="Viewport_PreviewMouseUp">
                <Grid x:Name="WorldLayer"
                      Canvas.Left="0"
                      Canvas.Top="0"
                      Width="20000"
                      Height="20000">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="WorldScale" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="WorldTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Canvas x:Name="ImageLayer" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <InkCanvas x:Name="Ink" Background="Transparent"/>
                </Grid>
            </Canvas>

            <Border x:Name="DragBar"
                    Background="#B0000000"
                    Height="28"
                    VerticalAlignment="Top"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Content="✕"
                            Width="40"
                            FontSize="14"
                            Style="{StaticResource ChromeButton}"
                            Click="Close_Click"
                            ToolTip="{DynamicResource Tooltip.Close}"/>
                    <Button DockPanel.Dock="Right"
                            Content="—"
                            Width="40"
                            FontSize="14"
                            Style="{StaticResource ChromeButton}"
                            Click="Minimize_Click"
                            ToolTip="{DynamicResource Tooltip.Minimize}"/>
                    <TextBlock Text="xsheet-mark"
                               Foreground="#E8E8E8"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               FontSize="12"/>
                </DockPanel>
            </Border>

            <Border Background="#A0000000"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Padding="8,4"
                    Margin="10"
                    CornerRadius="4"
                    IsHitTestVisible="False">
                <TextBlock x:Name="StatusText"
                           Text="{DynamicResource Status.Initial}"
                           Foreground="#E8E8E8"
                           FontFamily="Consolas"
                           FontSize="12"/>
            </Border>

            <Border Background="#C8000000"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,36,8,0"
                    Padding="10,6"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Slider.OpacityPrefix}"
                               Foreground="#E8E8E8"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource Slider.Window}"
                               Foreground="#E8E8E8"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <Slider x:Name="WindowOpacitySlider"
                            Orientation="Horizontal"
                            Width="100"
                            Minimum="0.2"
                            Maximum="1"
                            Value="1"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            VerticalAlignment="Center"
                            ValueChanged="WindowOpacity_ValueChanged"
                            ToolTip="{DynamicResource Tooltip.WindowOpacity}"/>
                    <TextBlock Text="{DynamicResource Slider.Image}"
                               Foreground="#E8E8E8"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="14,0,6,0"/>
                    <Slider x:Name="ImageOpacitySlider"
                            Orientation="Horizontal"
                            Width="100"
                            Minimum="0"
                            Maximum="1"
                            Value="1"
                            VerticalAlignment="Center"
                            ValueChanged="ImageOpacity_ValueChanged"
                            ToolTip="{DynamicResource Tooltip.ImageOpacity}"/>
                </StackPanel>
            </Border>

            <Border x:Name="Toolbar"
                    Background="#C8000000"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="8,36,0,0"
                    Padding="4"
                    CornerRadius="6">
                <StackPanel Orientation="Vertical">
                    <Button x:Name="UndoButton"
                            Style="{StaticResource ChromeButton}"
                            Content="↶"
                            Width="40" Height="40"
                            FontSize="18"
                            IsEnabled="False"
                            Click="Undo_Click"
                            ToolTip="{DynamicResource Tooltip.Undo}"/>
                    <Button x:Name="RedoButton"
                            Style="{StaticResource ChromeButton}"
                            Content="↷"
                            Width="40" Height="40"
                            FontSize="18"
                            IsEnabled="False"
                            Click="Redo_Click"
                            ToolTip="{DynamicResource Tooltip.Redo}"/>

                    <Rectangle Height="1" Margin="4,6" Fill="#40FFFFFF"/>

                    <RadioButton x:Name="PenTool"
                                 Style="{StaticResource ToolButton}"
                                 GroupName="Tools"
                                 Content="✎"
                                 Tag="Pen"
                                 IsChecked="True"
                                 Checked="OnToolChanged"
                                 ToolTip="{DynamicResource Tooltip.Pen}"/>
                    <RadioButton x:Name="EraserTool"
                                 Style="{StaticResource ToolButton}"
                                 GroupName="Tools"
                                 Content="⌫"
                                 Tag="Eraser"
                                 Checked="OnToolChanged"
                                 ToolTip="{DynamicResource Tooltip.Eraser}"/>
                    <RadioButton x:Name="MoveTool"
                                 Style="{StaticResource ToolButton}"
                                 GroupName="Tools"
                                 Content="✥"
                                 Tag="Move"
                                 Checked="OnToolChanged"
                                 ToolTip="{DynamicResource Tooltip.Move}"/>

                    <Rectangle Height="1" Margin="4,6" Fill="#40FFFFFF"/>

                    <Button x:Name="CurrentColorButton"
                            Style="{StaticResource CurrentColorSwatch}"
                            Background="#E04040"
                            PreviewMouseLeftButtonDown="CurrentColor_PreviewMouseDown"
                            PreviewMouseLeftButtonUp="CurrentColor_PreviewMouseUp"
                            MouseLeave="CurrentColor_MouseLeave"
                            ToolTip="{DynamicResource Tooltip.CurrentColor}"/>

                    <Popup x:Name="ColorPopup"
                           PlacementTarget="{Binding ElementName=CurrentColorButton}"
                           Placement="Right"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="#D8000000"
                                CornerRadius="6"
                                BorderBrush="#80FFFFFF"
                                BorderThickness="1"
                                Padding="6">
                            <StackPanel Orientation="Vertical">
                                <Button Style="{StaticResource PopupColorSwatch}"
                                        Background="#202020"
                                        Click="PickColor_Click"
                                        ToolTip="{DynamicResource Tooltip.ColorBlack}"/>
                                <Button Style="{StaticResource PopupColorSwatch}"
                                        Background="#FFFFFF"
                                        Click="PickColor_Click"
                                        ToolTip="{DynamicResource Tooltip.ColorWhite}"/>
                                <Button Style="{StaticResource PopupColorSwatch}"
                                        Background="#E04040"
                                        Click="PickColor_Click"
                                        ToolTip="{DynamicResource Tooltip.ColorRed}"/>
                                <Button Style="{StaticResource PopupColorSwatch}"
                                        Background="#4080E0"
                                        Click="PickColor_Click"
                                        ToolTip="{DynamicResource Tooltip.ColorBlue}"/>
                                <Button Style="{StaticResource PopupColorSwatch}"
                                        Background="#50B050"
                                        Click="PickColor_Click"
                                        ToolTip="{DynamicResource Tooltip.ColorGreen}"/>
                                <Button Style="{StaticResource PopupColorSwatch}"
                                        Background="#E0C040"
                                        Click="PickColor_Click"
                                        ToolTip="{DynamicResource Tooltip.ColorYellow}"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Rectangle Height="1" Margin="4,6" Fill="#40FFFFFF"/>

                    <RadioButton x:Name="WidthThin"
                                 Style="{StaticResource ToolButton}"
                                 GroupName="Widths"
                                 Tag="2"
                                 Checked="OnWidthChanged"
                                 ToolTip="{DynamicResource Tooltip.WidthThin}">
                        <Rectangle Width="24" Height="2" Fill="#E8E8E8"/>
                    </RadioButton>
                    <RadioButton x:Name="WidthMedium"
                                 Style="{StaticResource ToolButton}"
                                 GroupName="Widths"
                                 Tag="5"
                                 IsChecked="True"
                                 Checked="OnWidthChanged"
                                 ToolTip="{DynamicResource Tooltip.WidthMedium}">
                        <Rectangle Width="24" Height="5" Fill="#E8E8E8"/>
                    </RadioButton>
                    <RadioButton x:Name="WidthThick"
                                 Style="{StaticResource ToolButton}"
                                 GroupName="Widths"
                                 Tag="10"
                                 Checked="OnWidthChanged"
                                 ToolTip="{DynamicResource Tooltip.WidthThick}">
                        <Rectangle Width="24" Height="10" Fill="#E8E8E8"/>
                    </RadioButton>

                    <Rectangle Height="1" Margin="4,6" Fill="#40FFFFFF"/>

                    <Button Style="{StaticResource ChromeButton}"
                            Content="⛶"
                            Width="40" Height="40"
                            FontSize="18"
                            Click="FitAll_Click"
                            ToolTip="{DynamicResource Tooltip.FitAll}"/>

                    <Rectangle Height="1" Margin="4,6" Fill="#40FFFFFF"/>

                    <Button Style="{StaticResource ChromeButton}"
                            Content="💾"
                            Width="40" Height="40"
                            FontSize="16"
                            Click="ExportPsd_Click"
                            ToolTip="{DynamicResource Tooltip.ExportPsd}"/>
                    <Button Style="{StaticResource ChromeButton}"
                            Content="📷"
                            Width="40" Height="40"
                            FontSize="16"
                            Click="CapturePsd_Click"
                            ToolTip="{DynamicResource Tooltip.CapturePsd}"/>

                    <Rectangle Height="1" Margin="4,6" Fill="#40FFFFFF"/>

                    <Button x:Name="LockButton"
                            Style="{StaticResource ChromeButton}"
                            Content="🔒"
                            Width="40" Height="40"
                            FontSize="16"
                            Click="ToggleClickThrough_Click"
                            ToolTip="{DynamicResource Tooltip.Lock}"/>

                    <Button Style="{StaticResource ChromeButton}"
                            Content="🗑"
                            Width="40" Height="40"
                            FontSize="16"
                            Click="Reset_Click"
                            ToolTip="{DynamicResource Tooltip.Reset}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
